                   ),
                 ),
+                Text(
+                  'buf ${_secs(_stats['demuxer-cache-duration'])}',
+                  style: cStyle.copyWith(
+                    color: cachePaused
+                        ? const Color(0xFFFF5252)
+                        : Colors.white,
+                  ),
+                ),
               ],
             ),
           ),
