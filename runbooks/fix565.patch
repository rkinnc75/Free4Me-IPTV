     this.devInterpolation = false,
     this.devDeband = false,
+    this.devCapFpsLowRam = true,
     this.devHwdecImageFormat = HwdecImageFormat.defaultFmt,
     this.devAudioBufferSecs = 0.2,
     this.devControlsHideSecs = 3,
