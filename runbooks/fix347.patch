diff --git a/lib/settings_view.dart b/lib/settings_view.dart
index 0b8122f..884e264 100644
--- a/lib/settings_view.dart
+++ b/lib/settings_view.dart
@@ -1108,8 +1108,38 @@ class _SettingsState extends State<SettingsView> {
