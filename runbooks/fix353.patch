diff --git a/test/series_episodes_test.dart b/test/series_episodes_test.dart
new file mode 100644
index 0000000..ea1d180
--- /dev/null
+++ b/test/series_episodes_test.dart
@@ -0,0 +1,155 @@
+// fix353: Rule 8 as a permanent test. channels_unique_series was
+// (source_id, series_id) — one row per series — collapsing every inserted
+// episode of a series onto a single row via insertChannel's bare upsert
+// ("series loads 1 episode"). Migration 28 re-keys the partial index on
+// (source_id, series_id, url) so episodes coexist while re-fetches still
+// dedupe. This test runs the VERBATIM upsert column set against a real
+// sqlite DB seeded with the pre-28 index: reproduces the collapse, applies
+// the migration SQL, and proves fix + self-heal + idempotence + an
+// untouched parent row.
+import 'package:flutter_test/flutter_test.dart';
+import 'package:sqlite3/sqlite3.dart' as s3;
+
+bool _sqliteAvailable() {
+  try {
+    s3.sqlite3.openInMemory().dispose();
+    return true;
+  } catch (_) {
+    return false;
+  }
+}
+
+const _schema = '''
+CREATE TABLE channels (
+  id INTEGER PRIMARY KEY, name TEXT, image TEXT, url TEXT, source_id INTEGER,
+  media_type INTEGER, series_id INTEGER, favorite INTEGER, stream_id INTEGER,
+  group_name TEXT, epg_channel_id TEXT, catchup_type TEXT, catchup_source TEXT,
+  catchup_days INTEGER, provider_order INTEGER, is_divider INTEGER,
+  is_adult INTEGER, last_watched INTEGER, stream_validated INTEGER
+);
+CREATE UNIQUE INDEX channels_unique_stream
+  ON channels(source_id, media_type, stream_id)
+  WHERE stream_id IS NOT NULL AND stream_id >= 0;
+-- pre-migration-28 (fix178) form:
+CREATE UNIQUE INDEX channels_unique_series
+  ON channels(source_id, series_id)
+  WHERE series_id IS NOT NULL;
+''';
+
+// Verbatim migration 28 statements (db_factory.dart).
+const _mig28a = 'DROP INDEX IF EXISTS channels_unique_series;';
+const _mig28b = '''
+CREATE UNIQUE INDEX IF NOT EXISTS channels_unique_series
+ON channels(source_id, series_id, url)
+WHERE series_id IS NOT NULL;
+''';
+
+// Same column set + conflict clause as Sql.insertChannel.
+const _upsert = '''
+INSERT INTO channels (
+  name, image, url, source_id, media_type, series_id, favorite,
+  stream_id, group_name, epg_channel_id,
+  catchup_type, catchup_source, catchup_days, provider_order, is_divider,
+  is_adult
+)
+VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+ON CONFLICT DO UPDATE SET
+  url = excluded.url,
+  group_name = excluded.group_name,
+  media_type = excluded.media_type,
+  stream_id = excluded.stream_id,
+  image = excluded.image,
+  series_id = excluded.series_id,
+  epg_channel_id = COALESCE(channels.epg_channel_id, excluded.epg_channel_id),
+  catchup_type = excluded.catchup_type,
+  catchup_source = excluded.catchup_source,
+  catchup_days = excluded.catchup_days,
+  provider_order = excluded.provider_order,
+  is_divider = excluded.is_divider,
+  is_adult = excluded.is_adult;
+''';
+
+void _insertEpisode(s3.Database db, String name, String url, int seriesId) {
+  db.execute(_upsert, [
+    name, null, url, 5, 1, seriesId, 0,
+    null, null, null, null, null, null, null, 0, 0,
+  ]);
+}
+
+int _episodeCount(s3.Database db, int seriesId) => db
+    .select('SELECT COUNT(*) c FROM channels WHERE series_id = ?', [seriesId])
+    .first['c'] as int;
+
+void main() {
+  if (!_sqliteAvailable()) {
+    test('sqlite3 native library unavailable — migration-28 test skipped', () {
+      expect(true, isTrue);
+    });
+    return;
+  }
+
+  group('migration 28: series episodes coexist and dedupe', () {
+    late s3.Database db;
+    final eps = [
+      ('S01E01', 'https://x/series/u/p/9001.mkv'),
+      ('S01E02', 'https://x/series/u/p/9002.mkv'),
+      ('S01E03', 'https://x/series/u/p/9003.mkv'),
+    ];
+
+    setUp(() {
+      db = s3.sqlite3.openInMemory();
+      db.execute(_schema);
+      // Series parent exactly as xtreamToChannel builds it: series_id NULL,
+      // the provider series id stored in url, stream_id sentinel -1.
+      db.execute(
+        'INSERT INTO channels (name, url, source_id, media_type, series_id,'
+        ' favorite, stream_id, group_name)'
+        " VALUES ('Breaking Bad', '777', 5, 2, NULL, 0, -1, 'Drama');",
+      );
+    });
+    tearDown(() => db.dispose());
+
+    test('pre-28 schema reproduces the 1-episode collapse', () {
+      for (final (name, url) in eps) {
+        _insertEpisode(db, name, url, 777);
+      }
+      expect(_episodeCount(db, 777), 1, reason: 'collapse is the known bug');
+    });
+
+    test('migration 28 fixes, self-heals, and stays idempotent', () {
+      // Collapsed legacy state first.
+      for (final (name, url) in eps) {
+        _insertEpisode(db, name, url, 777);
+      }
+      expect(_episodeCount(db, 777), 1);
+
+      db.execute(_mig28a);
+      db.execute(_mig28b);
+
+      // Self-heal: re-fetch upserts the stale row and inserts the rest.
+      for (final (name, url) in eps) {
+        _insertEpisode(db, name, url, 777);
+      }
+      expect(_episodeCount(db, 777), 3);
+
+      // Idempotence: another fetch must not duplicate.
+      for (final (name, url) in eps) {
+        _insertEpisode(db, name, url, 777);
+      }
+      expect(_episodeCount(db, 777), 3);
+
+      // Parent untouched: one row, still media_type=serie(2).
+      final p = db.select(
+        "SELECT COUNT(*) c, MAX(media_type) m FROM channels"
+        " WHERE name = 'Breaking Bad'",
+      ).first;
+      expect(p['c'], 1);
+      expect(p['m'], 2);
+
+      // A second series on the same source coexists.
+      _insertEpisode(db, 'S01E01', 'https://x/series/u/p/555.mkv', 888);
+      expect(_episodeCount(db, 888), 1);
+      expect(_episodeCount(db, 777), 3);
+    });
+  });
+}
