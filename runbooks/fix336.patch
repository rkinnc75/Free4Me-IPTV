+            icon: const Icon(Icons.replay_10, color: Colors.white, size: 30),
+            tooltip: 'Back 10s',
+          ),
+          IconButton(
+            autofocus: true,
+            onPressed: () async {
+              if (_vodPlaying) {
+                await _engine.pause();
+                if (mounted) setState(() => _vodPlaying = false);
+              } else {
+                await _engine.play();
+                if (mounted) setState(() => _vodPlaying = true);
+              }
+            },
+            icon: Icon(_vodPlaying ? Icons.pause : Icons.play_arrow,
